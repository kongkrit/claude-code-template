{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "cat \"$CLAUDE_PROJECT_DIR/PROGRESS.md\" 2>/dev/null || true" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(sudo apt install:*)",
      "Bash(sudo apt update:*)"
    ]
  },
  "model": "opus",
  "effortLevel": "xhigh"
}
