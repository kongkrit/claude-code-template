# Default: normalise line endings to LF in the repo
* text=auto eol=lf

# Prose / structured text
*.md        text eol=lf
*.txt       text eol=lf
*.csv       text eol=lf
*.tsv       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.html      text eol=lf

# Code
*.py        text eol=lf
*.r         text eol=lf
*.R         text eol=lf
*.ipynb     text eol=lf
*.sh        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.jsx       text eol=lf
*.tsx       text eol=lf

# Binary — never diff or merge
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.svg       binary
*.ico       binary
*.xlsx      binary
*.xls       binary
*.docx      binary
*.doc       binary
*.zip       binary
*.tar.gz    binary
